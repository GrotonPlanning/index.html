<style>
body {
  margin: 0;
  overflow-x: hidden;
  font-family: Arial, sans-serif;
}

/* WRAPPER */
.viewer-wrapper {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

/* SCROLL AREA */
.viewer {
  display: flex;
  height: 100%;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  align-items: center;
  gap: 60px;
  padding: 40px;
}

/* Hide scrollbar */
.viewer::-webkit-scrollbar {
  display: none;
}

/* NAV BUTTONS */
.nav {
  position: fixed;
  top: 50%;
  transform: translateY(-50%);
  z-index: 999;
  font-size: 32px;
  background: rgba(0,0,0,0.5);
  color: white;
  border: none;
  padding: 12px 16px;
  cursor: pointer;
}

.nav.left { left: 10px; }
.nav.right { right: 10px; }

/* BOARDS */
.board {
  flex: 0 0 auto;
  scroll-snap-align: center;
  cursor: pointer;
}

.board-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  max-height: 75vh;
}

.board-inner img {
  max-height: 75vh;
  max-width: 90vw;
  width: auto;
  height: auto;
  object-fit: contain;
}

.board-title {
  text-align: center;
  margin-top: 10px;
  font-size: 14px;
}

/* MODAL */
.modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.9);
  z-index: 1000;
  justify-content: center;
  align-items: center;
}

.modal img {
  max-width: 95%;
  max-height: 95%;
}

.modal.active {
  display: flex;
}
</style>

